---
---

<section id="subscribe" class="py-16 lg:py-20 border-y border-[#111111]">
  <div class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-2xl mx-auto text-center">
      <span class="font-mono text-xs uppercase tracking-widest text-[#CC0000]">
        Stay Informed
      </span>
      <h2 class="font-serif font-black text-[#111111] text-3xl sm:text-4xl lg:text-5xl tracking-tight mt-4 mb-4">
        The Daily Chronicle Newsletter
      </h2>
      <p class="font-body text-neutral-600 text-lg leading-relaxed mb-8">
        Get the day's top stories delivered to your inbox every morning. 
        Curated by our editors, trusted by over 2 million readers.
      </p>
      
      <form class="flex flex-col sm:flex-row gap-4 max-w-lg mx-auto">
        <input 
          type="email"
          placeholder="Enter your email"
          class="flex-1 border-b-2 border-[#111111] bg-transparent px-4 py-3 font-mono text-sm focus-visible:bg-[#F0F0F0] focus-visible:outline-none placeholder:text-neutral-400 min-h-[44px]"
          required
        />
        <button 
          type="submit"
          class="bg-[#111111] text-[#F9F9F7] px-8 py-3 font-sans text-sm font-semibold uppercase tracking-widest hover:bg-white hover:text-[#111111] hover:border hover:border-[#111111] transition-all duration-200 min-h-[44px]"
        >
          Subscribe
        </button>
      </form>
      
      <p class="font-mono text-xs text-neutral-400 mt-4">
        No spam. Unsubscribe at any time.
      </p>
    </div>
  </div>
</section>
