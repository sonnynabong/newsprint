---
import type { Article } from '../../data/articles.ts';
import { ArrowRight } from '../icons/index.tsx';

interface Props {
  article: Article;
}

const { article } = Astro.props;
---

<section class="border-b border-[#111111]">
  <div class="max-w-screen-xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-12">
      {/* Main Article */}
      <div class="lg:col-span-8 border-b lg:border-b-0 lg:border-r border-[#111111]">
        <a href={`/article/${article.id}`} class="block group">
          <div class="aspect-[16/9] overflow-hidden bg-neutral-200">
            <img 
              src={article.imageUrl} 
              alt={article.imageCaption}
              class="w-full h-full object-cover grayscale group-hover:sepia-[50%] transition-all duration-200"
            />
          </div>
          <div class="p-6 lg:p-10">
            <div class="flex items-center gap-3 mb-4">
              <span class="bg-[#CC0000] text-white font-sans text-xs font-bold uppercase tracking-widest px-2 py-1">
                Breaking
              </span>
              <span class="font-mono text-xs uppercase tracking-widest text-neutral-500">
                {article.category}
              </span>
            </div>
            <h2 class="font-serif font-black text-[#111111] text-4xl sm:text-5xl lg:text-6xl xl:text-7xl leading-[0.95] tracking-tight mb-6">
              {article.headline}
            </h2>
            <p class="font-body text-[#111111] text-lg lg:text-xl leading-relaxed mb-6 max-w-3xl">
              {article.excerpt}
            </p>
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-4">
                <span class="font-mono text-xs uppercase tracking-widest text-neutral-500">
                  By {article.author}
                </span>
                <span class="font-mono text-xs text-neutral-400">
                  {new Date(article.publishedAt).toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' })}
                </span>
              </div>
              <span class="inline-flex items-center gap-2 font-sans text-sm font-semibold uppercase tracking-widest text-[#111111] group-hover:text-[#CC0000] transition-colors duration-200">
                Read Full Story
                <ArrowRight className="h-4 w-4" strokeWidth={2} />
              </span>
            </div>
          </div>
        </a>
      </div>

      {/* Sidebar - Secondary Stories */}
      <div class="lg:col-span-4">
        <div class="border-b border-[#111111] p-6 lg:p-8">
          <h3 class="font-sans text-xs font-bold uppercase tracking-widest text-[#111111] mb-6">
            Latest Updates
          </h3>
          <div class="space-y-6">
            {/* Quick News Items */}
            <a href="#" class="block group">
              <span class="font-mono text-xs uppercase tracking-widest text-[#CC0000]">Just In</span>
              <h4 class="font-serif font-bold text-lg mt-1 group-hover:text-[#CC0000] transition-colors duration-200">
                Markets Rally as Inflation Concerns Ease
              </h4>
              <span class="font-mono text-xs text-neutral-500 mt-1 block">2 min ago</span>
            </a>
            
            <div class="border-t border-[#111111]"></div>
            
            <a href="#" class="block group">
              <span class="font-mono text-xs uppercase tracking-widest text-neutral-500">World</span>
              <h4 class="font-serif font-bold text-lg mt-1 group-hover:text-[#CC0000] transition-colors duration-200">
                Historic Peace Treaty Signed in Middle East
              </h4>
              <span class="font-mono text-xs text-neutral-500 mt-1 block">15 min ago</span>
            </a>
            
            <div class="border-t border-[#111111]"></div>
            
            <a href="#" class="block group">
              <span class="font-mono text-xs uppercase tracking-widest text-neutral-500">Science</span>
              <h4 class="font-serif font-bold text-lg mt-1 group-hover:text-[#CC0000] transition-colors duration-200">
                Webb Telescope Discovers Potentially Habitable Exoplanet
              </h4>
              <span class="font-mono text-xs text-neutral-500 mt-1 block">32 min ago</span>
            </a>
            
            <div class="border-t border-[#111111]"></div>
            
            <a href="#" class="block group">
              <span class="font-mono text-xs uppercase tracking-widest text-neutral-500">Sports</span>
              <h4 class="font-serif font-bold text-lg mt-1 group-hover:text-[#CC0000] transition-colors duration-200">
                Underdog Team Wins Championship in Historic Upset
              </h4>
              <span class="font-mono text-xs text-neutral-500 mt-1 block">1 hour ago</span>
            </a>
          </div>
        </div>

        {/* Weather Widget */}
        <div class="p-6 lg:p-8 bg-[#111111] text-white">
          <div class="flex items-center justify-between">
            <div>
              <span class="font-mono text-xs uppercase tracking-widest text-neutral-400">New York</span>
              <div class="font-serif font-bold text-4xl mt-1">68°F</div>
              <span class="font-sans text-sm text-neutral-400">Partly Cloudy</span>
            </div>
            <div class="text-right">
              <div class="font-mono text-xs uppercase tracking-widest text-neutral-400">High / Low</div>
              <div class="font-serif text-xl mt-1">72° / 58°</div>
            </div>
          </div>
          <div class="mt-4 pt-4 border-t border-neutral-700">
            <div class="flex justify-between font-mono text-xs">
              <span class="text-neutral-400">Humidity: 62%</span>
              <span class="text-neutral-400">Wind: 8 mph</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
