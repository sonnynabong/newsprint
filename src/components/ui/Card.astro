---
interface Props {
  hoverable?: boolean;
  class?: string;
}

const { hoverable = false, class: className = '' } = Astro.props;
---

<div class={`
  border border-[#111111] 
  bg-[#F9F9F7] 
  overflow-hidden
  ${hoverable ? 'hard-shadow-hover cursor-pointer' : ''}
  ${className}
`}>
  <slot />
</div>
